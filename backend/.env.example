# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────
# For local TCP: postgresql://postgres:password@localhost:5432/bluefage_events
# For Unix socket: postgresql://postgres@/bluefage_events?host=/var/run/postgresql
DATABASE_URL=postgresql://postgres:password@localhost:5432/bluefage_events

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (Nodemailer) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Bluefage Events <noreply@bluefageevents.com>

# ─── Upload ───────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000

# ─── Frontend URL (for CORS) ──────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Admin Defaults ───────────────────────────────────
ADMIN_EMAIL=admin@bluefageevents.com
ADMIN_PASSWORD=Admin@123456
